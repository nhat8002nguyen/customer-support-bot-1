# OpenAI
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=

# Zendesk (support.optisigns.com via public API)
ZENDESK_BASE_URL=https://support.optisigns.com

# Paths (defaults shown)
DATA_DIR=data/articles
STATE_FILE_PATH=optibot/state.json

# State backend: "local" (filesystem) or "spaces" (DO Spaces)
STATE_BACKEND=local

# DigitalOcean Spaces (required when STATE_BACKEND=spaces)
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_BUCKET=
SPACES_REGION=sgp1

# Job log sharing (off = disabled, local = file, spaces = DO Spaces)
JOB_LOG_BACKEND=off
JOB_LOG_PATH=optibot/job.log

# Limit pages to scrape (0 = unlimited)
MAX_PAGES=2

# Minimum articles required for a successful run (0 = no check)
MIN_ARTICLES=0

# Zendesk fetch retries per page
FETCH_RETRIES=3

# Seconds to wait for OpenAI vector-store file processing
POLL_TIMEOUT_S=180
